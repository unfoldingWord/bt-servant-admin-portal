#!/usr/bin/env sh

echo "Running secret scan..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --staged --no-banner --exit-code 1
elif [ -x "$HOME/.local/bin/gitleaks" ]; then
  "$HOME/.local/bin/gitleaks" git --staged --no-banner --exit-code 1
else
  echo "WARNING: gitleaks not found — skipping secret scan"
fi

echo "Running dependency audit (production)..."
npm audit --omit=dev --audit-level=moderate

npx lint-staged
npm run typecheck
npm run build
